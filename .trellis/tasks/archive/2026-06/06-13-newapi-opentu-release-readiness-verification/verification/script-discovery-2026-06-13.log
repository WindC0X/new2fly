=== opentu root package scripts ===
{
  "start": "nx run web:serve-pwa",
  "build": "node scripts/update-version.js && nx run-many -t=build",
  "build:web": "node scripts/update-version.js && nx build web",
  "preview": "npx serve dist/apps/web -l 7288",
  "preview:watch": "concurrently -k \"cd apps/web && NODE_OPTIONS='--max-old-space-size=8192' npx vite build --watch\" \"npx wait-on dist/apps/web/index.html && npx serve dist/apps/web -l 7288\"",
  "iframe:test:host": "python3 -m http.server 7201 -d apps/web/public",
  "iframe:test": "node scripts/iframe-test-dev.js",
  "package": "pnpm build && node scripts/create-deploy-package.js",
  "typecheck": "nx run-many -t=typecheck",
  "lint": "nx run-many -t=lint",
  "check": "pnpm typecheck && pnpm lint",
  "test": "nx run-many -t=test",
  "e2e": "nx e2e web-e2e",
  "e2e:smoke": "nx e2e web-e2e -- --project=smoke",
  "e2e:visual": "nx e2e web-e2e -- --project=visual",
  "e2e:visual:update": "nx e2e web-e2e -- --project=visual --update-snapshots",
  "e2e:visual:report": "npx playwright show-report apps/web-e2e/playwright-report",
  "e2e:features": "nx e2e web-e2e -- --project=chromium",
  "e2e:manual": "nx e2e web-e2e -- --project=manual",
  "manual:screenshots": "cd apps/web-e2e && CI= npx playwright test --project=manual",
  "manual:build": "npx ts-node --compiler-options '{\"module\":\"commonjs\",\"esModuleInterop\":true}' scripts/generate-manual.ts",
  "manual:update": "pnpm manual:screenshots && pnpm manual:build",
  "manual:dev": "pnpm manual:update",
  "manual:record": "cd apps/web-e2e && npx playwright codegen http://localhost:7200",
  "manual:video": "cd apps/web-e2e && CI= npx playwright test --project=manual-video -g 'GIF 动图录制'",
  "manual:gif": "pnpm manual:video && node scripts/video-to-gif.js && pnpm manual:build",
  "manual:gif:mindmap": "cd apps/web-e2e && CI= npx playwright test --project=manual-video -g '思维导图创建演示' && node scripts/video-to-gif.js --test 思维导图 --trim 2.4 && pnpm manual:build",
  "manual:video2gif": "node scripts/video-to-gif.js",
  "size": "size-limit",
  "size:why": "size-limit --why",
  "version:patch": "node scripts/safe-version-bump.js patch",
  "version:minor": "node scripts/safe-version-bump.js minor",
  "version:major": "node scripts/safe-version-bump.js major",
  "release:skip": "node scripts/deploy-hybrid.js --skip-build --skip-e2e --skip-npm --skip-manual",
  "release": "node scripts/deploy-hybrid.js --skip-e2e --skip-manual",
  "release:minor": "node scripts/deploy-hybrid.js --bump-if-published=minor",
  "release:major": "node scripts/deploy-hybrid.js --bump-if-published=major",
  "release:retry": "node scripts/deploy-hybrid.js --skip-e2e  --skip-manual",
  "release:force-bump": "pnpm version:patch && node scripts/deploy-hybrid.js --skip-e2e",
  "release:dry": "node scripts/deploy-hybrid.js --dry-run",
  "release:rollback": "node scripts/rollback-hybrid.js --test",
  "release:preview": "pnpm build:web && npx serve -s dist/apps/web -l 7289",
  "rollback": "node scripts/rollback-release.js",
  "pub": "pnpm build && node scripts/publish.js",
  "npm:publish": "node scripts/publish-npm.js",
  "npm:publish:dry": "node scripts/publish-npm.js --dry-run",
  "npm:publish:skip-build": "node scripts/publish-npm.js --skip-build",
  "check:cycles": "node scripts/check-cycles.js",
  "check:cycles:types": "node scripts/check-cycles.js --include-types",
  "verify:startup": "node scripts/validate-startup-bundle.js",
  "deploy:upload": "node scripts/upload-and-deploy.js",
  "deploy:nginx": "node scripts/upload-nginx-config.js"
}
