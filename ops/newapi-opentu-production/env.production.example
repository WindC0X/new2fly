# New API + embedded Creative production env checklist/template
# -----------------------------------------------------------------------------
# This is NOT a full .env file and must NOT be copied over production .env.
# Use it as a checklist or append/update only the reviewed Creative keys.
# Keep real values in the target host/secret manager. Do not commit real values.

# -----------------------------------------------------------------------------
# Existing production values to preserve on VPS-A
# -----------------------------------------------------------------------------
# Verify these exist in the current production .env/container env, but do not
# replace them with placeholders from this file.
# PORT=<existing-production-port-currently-13000>
# GIN_MODE=release
# TZ=<existing-production-timezone-currently-Asia/Hong_Kong>
# SESSION_SECRET=<keep-existing-stable-production-value>
# SQLITE_PATH=<keep-existing-production-db-path>
# SQL_DSN=<keep-existing-production-value-if-used>
# LOG_SQL_DSN=<keep-existing-production-value-if-used>
# REDIS_CONN_STRING=<keep-existing-production-value-if-used>

# FRONTEND_BASE_URL should stay empty unless the deployment intentionally hosts
# the default console frontend elsewhere. If set, post-deploy checks must prove
# /creative/api/* and /creative/relay/* remain local API/relay boundaries.
# FRONTEND_BASE_URL=<empty-or-reviewed-url>

# -----------------------------------------------------------------------------
# Phase 1: embedded Creative routes only, production 云同步 disabled
# -----------------------------------------------------------------------------
# Append/update these keys for the first production route/UI cutover.
# Do not enable DB-backed Creative asset sync in production.
# CREATIVE_ASSET_SYNC_ENABLED=false
# CREATIVE_VIDEO_RELAY_ENABLED=false

# -----------------------------------------------------------------------------
# Phase 2: enable Creative 云同步 with private S3-compatible storage
# -----------------------------------------------------------------------------
# Use this block only after S3/R2/OSS-compatible storage is ready.
# When enabling Phase 2, ensure there is exactly one CREATIVE_ASSET_SYNC_ENABLED
# key in the effective env and its final value is true.
# CREATIVE_ASSET_SYNC_ENABLED=true
# CREATIVE_ASSET_ROLLOUT_MODE=production
# CREATIVE_ASSET_STORAGE=s3-compatible
# CREATIVE_ASSET_S3_ENDPOINT=<private-object-storage-endpoint>
# CREATIVE_ASSET_S3_REGION=<region-or-auto>
# CREATIVE_ASSET_S3_BUCKET=<private-bucket>
# CREATIVE_ASSET_S3_PREFIX=creative-assets
# CREATIVE_ASSET_S3_ACCESS_KEY_ID=<secret>
# CREATIVE_ASSET_S3_SECRET_ACCESS_KEY=<secret>
# CREATIVE_ASSET_S3_FORCE_PATH_STYLE=false
# CREATIVE_ASSET_USER_MAX_BYTES=2147483648
# CREATIVE_ASSET_USER_MAX_ASSETS=10000
